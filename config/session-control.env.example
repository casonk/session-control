# session-control local runtime settings.
# Copy to config/session-control.env.local and keep the .local file untracked.

SESSION_CONTROL_HOST=127.0.0.1
SESSION_CONTROL_PORT=5420

# Keep the app on loopback by default. Prefer Caddy/mTLS or WireGuard for phone access.
# SESSION_CONTROL_ALLOW_REMOTE=0
# SESSION_CONTROL_PUBLIC_ORIGIN=https://session-control.example.local
# SESSION_CONTROL_ALLOWED_ORIGINS=https://session-control.example.local

# Provider roots. Defaults are shown for clarity.
# SESSION_CONTROL_CODEX_ROOT=~/.codex
# SESSION_CONTROL_CLAUDE_ROOT=~/.claude
# SESSION_CONTROL_CONTINUE_ROOT=~/.continue
# SESSION_CONTROL_COPILOT_ROOT=~/.copilot

# Optional Codex resume fallback. Leave unset to use the model recorded in each
# Codex session. Set this when your global Codex default is not supported by the
# auth mode used on this machine.
# SESSION_CONTROL_CODEX_RESUME_MODEL=gpt-5.4

# Delete destination.
# SESSION_CONTROL_TRASH_DIR=~/.local/share/session-control/trash

# Scheduled pruning threshold. Supports h, d, or w suffixes.
# SESSION_CONTROL_PRUNE_OLDER_THAN=180d

# Set a stable secret for persistent browser sessions when running as a service.
# SESSION_CONTROL_SECRET_KEY=change-me-to-a-local-random-value

# Web terminal integration. Set the URL of your ttyd/webterm instance to enable
# the Open button. SESSION_CONTROL_TMUX_SESSION is the base tmux session name
# that the webterm is attached to (default: pit-box).
# SESSION_CONTROL_WEBTERM_URL=https://webterm.example.local
# SESSION_CONTROL_TMUX_SESSION=pit-box
